# ─────────────────────────────────────────────────────────────────────────────
# auth-cloak environment variables
# Copy to .env and fill in real values. Never commit .env.
# Generate strong passwords with: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ── Keycloak bootstrap admin ──────────────────────────────────────────────────
# Only effective on FIRST start (before master realm exists).
# Change via Admin UI immediately after first deploy, then rotate this value.
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_random_password

# ── Keycloak hostname ─────────────────────────────────────────────────────────
KC_HOSTNAME=***.***.ac.za

# ── Nginx admin access control ────────────────────────────────────────────────
# CIDR range(s) allowed to reach /admin and /realms/master.
# Uses the server's LAN subnet. VPN clients land here.
ADMIN_ALLOWED_CIDR=***.***.***.*/**

# ── Backup settings ───────────────────────────────────────────────────────────
BACKUP_DIR=/**/******/*****/backups
BACKUP_RETENTION_DAYS=30

# ── SMTP (required for password-reset emails — configure when available) ──────
# Until configured, password reset emails will not be sent.
# Set these values then configure in Keycloak Admin UI:
#   Realm Settings → Email → SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@saeon.ac.za
SMTP_FROM_DISPLAY_NAME="SAEON Auth"
SMTP_STARTTLS=true
SMTP_SSL=false
